{
  "id": "video-i2v",
  "name": "Image to Video (Wan2.2 5B)",
  "description": "Animate a reference image into video using Wan2.2 5B model",
  "engine": "comfyui",
  "vramRequired": 6,
  "estimatedTime": "60-180s",
  "outputType": "video",
  "workflow": {
    "37": {
      "class_type": "UNETLoader",
      "inputs": {
        "unet_name": "wan2.2_ti2v_5B_fp16.safetensors",
        "weight_dtype": "default"
      }
    },
    "38": {
      "class_type": "CLIPLoader",
      "inputs": {
        "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
        "type": "wan",
        "device": "default"
      }
    },
    "39": {
      "class_type": "VAELoader",
      "inputs": {
        "vae_name": "wan2.2_vae.safetensors"
      }
    },
    "48": {
      "class_type": "ModelSamplingSD3",
      "inputs": {
        "shift": 8.0,
        "model": ["37", 0]
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{positive}}",
        "clip": ["38", 0]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{negative}}",
        "clip": ["38", 0]
      }
    },
    "10": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "{{start_image}}"
      }
    },
    "55": {
      "class_type": "Wan22ImageToVideoLatent",
      "inputs": {
        "vae": ["39", 0],
        "start_image": ["10", 0],
        "width": 480,
        "height": 272,
        "length": 33,
        "batch_size": 1
      }
    },
    "3": {
      "class_type": "KSampler",
      "inputs": {
        "seed": -1,
        "steps": 30,
        "cfg": 5,
        "sampler_name": "uni_pc",
        "scheduler": "simple",
        "denoise": 1,
        "model": ["48", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["55", 0]
      }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["3", 0],
        "vae": ["39", 0]
      }
    },
    "28": {
      "class_type": "SaveAnimatedWEBP",
      "inputs": {
        "filename_prefix": "flowcut_i2v",
        "fps": 16,
        "lossless": false,
        "quality": 90,
        "method": "default",
        "images": ["8", 0]
      }
    }
  },
  "params": {
    "positive": "string",
    "negative": "string?",
    "start_image": "string",
    "width": "number?",
    "height": "number?",
    "length": "number?",
    "steps": "number?"
  }
}
