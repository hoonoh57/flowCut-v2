{
  "id": "bgm-ace-step",
  "name": "BGM (ACE-Step v1)",
  "description": "AI music generation via ACE-Step 3.5B",
  "engine": "comfyui",
  "vramRequired": 8,
  "estimatedTime": "30-120s",
  "outputType": "audio",
  "workflow": {
    "40": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": { "ckpt_name": "ace_step_v1_3.5b.safetensors" }
    },
    "51": {
      "class_type": "ModelSamplingSD3",
      "inputs": { "shift": 5.0, "model": ["40", 0] }
    },
    "50": {
      "class_type": "LatentOperationTonemapReinhard",
      "inputs": { "multiplier": 1.0 }
    },
    "49": {
      "class_type": "LatentApplyOperationCFG",
      "inputs": { "model": ["51", 0], "operation": ["50", 0] }
    },
    "17": {
      "class_type": "EmptyAceStepLatentAudio",
      "inputs": { "seconds": "{{duration}}", "batch_size": 1 }
    },
    "14": {
      "class_type": "TextEncodeAceStepAudio",
      "inputs": {
        "clip": ["40", 1],
        "tags": "{{tags}}",
        "lyrics": "{{lyrics}}",
        "singer_wav_vol_peak": 0.99,
        "lyrics_strength": 0.99
      }
    },
    "44": {
      "class_type": "ConditioningZeroOut",
      "inputs": { "conditioning": ["14", 0] }
    },
    "52": {
      "class_type": "KSampler",
      "inputs": {
        "model": ["49", 0],
        "positive": ["14", 0],
        "negative": ["44", 0],
        "latent_image": ["17", 0],
        "seed": -1,
        "steps": 50,
        "cfg": 5,
        "sampler_name": "euler",
        "scheduler": "simple",
        "denoise": 1
      }
    },
    "18": {
      "class_type": "VAEDecodeAudio",
      "inputs": { "samples": ["52", 0], "vae": ["40", 2] }
    },
    "59": {
      "class_type": "SaveAudioMP3",
      "inputs": { "audio": ["18", 0], "filename_prefix": "flowcut_bgm", "quality": "V0" }
    }
  },
  "params": {
    "tags": "string",
    "lyrics": "string?",
    "duration": "number"
  }
}